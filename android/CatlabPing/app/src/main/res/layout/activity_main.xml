<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF5F5F5">

    <!-- 可滚动的主内容区 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 顶部标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🐱"
                android:textSize="36sp"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="CatlabPing"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FF2D2D2D"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="AstrBot 插件伴侣"
                android:textSize="12sp"
                android:textColor="#FF999999"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="20dp" />

            <!-- 📍 位置查岗 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="#FFFFFFFF"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍 位置查岗"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#FF2D2D2D" />

                        <TextView
                            android:id="@+id/tv_location_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="○ 未启动"
                            android:textSize="12sp"
                            android:textColor="#FF9E9E9E"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_location_settings"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="设置"
                        android:textSize="12sp"
                        android:minWidth="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 📱 手机使用监控 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="#FFFFFFFF"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📱 手机使用监控"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#FF2D2D2D" />

                        <TextView
                            android:id="@+id/tv_screenshot_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="○ 未启动"
                            android:textSize="12sp"
                            android:textColor="#FF9E9E9E"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_screenshot_settings"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="设置"
                        android:textSize="12sp"
                        android:minWidth="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_screenshot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 🔮 敬请期待 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/dashed_border">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔮"
                    android:textSize="20sp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="更多功能，敬请期待..."
                    android:textSize="14sp"
                    android:textColor="#FFBBBBBB" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 底部固定信息栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:background="#FFF5F5F5">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="请确保已授予所需权限 · 建议关闭电池优化"
            android:textSize="11sp"
            android:textColor="#FFBBBBBB"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2026 沈菀 (Akusative) | AGPL-3.0 · v3.1.0"
            android:textSize="11sp"
            android:textColor="#FFCCCCCC"
            android:gravity="center"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</LinearLayout>
